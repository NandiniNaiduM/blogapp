<!DOCTYPE html>
<html>

<head>

    <title>My Blog</title>

    <link rel="stylesheet" href="/style.css">

</head>

<body>

    <header>

        <h1>My Blog</h1>

        <p>Share Your Thoughts With The World</p>

    </header>

    <div class="container">

        <% blogs.forEach(blog=> { %>

            <div class="card">

    <h2><%= blog.title %></h2>

    <p><%= blog.content %></p>

    <form action="/delete-blog/<%= blog._id %>" method="POST">

        <button class="delete-btn">

            Delete

        </button>

    </form>

</div>
        <% }) %>

    </div>
    <div class="form-container">

    <form action="/add-blog" method="POST">

        <input
            type="text"
            name="title"
            placeholder="Enter Blog Title"
            required>

        <textarea
            name="content"
            placeholder="Write your blog..."
            rows="5"
            required></textarea>

        <button type="submit">
            Publish Blog
        </button>

    </form>

</div>

</body>

</html>